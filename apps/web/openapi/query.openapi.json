  "paths": {
    "/listings": {
      "get": {
        "summary": "Browse Listings",
        "operationId": "browse_listings_listings_get",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 60,
              "minimum": 1,
              "default": 24,
              "title": "Limit"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 10000,
              "minimum": 0,
              "default": 0,
              "title": "Offset"
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^(rating|reviews|name)$",
              "default": "rating",
              "title": "Sort"
            }
          },
          {
            "name": "include_facets",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "Include city/category facet counts",
              "default": false,
              "title": "Include Facets"
            },
            "description": "Include city/category facet counts"
          },
          {
            "name": "price_max",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "maximum": 4,
                  "minimum": 1
                },
                {
                  "type": "null"
                }
              ],
              "description": "Max price level (1-4)",
              "title": "Price Max"
            },
            "description": "Max price level (1-4)"
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "null"
                }
              ],
              "description": "Category filter",
              "title": "Category"
            },
            "description": "Category filter"
          },
          {
            "name": "city",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "null"
                }
              ],
              "description": "City filter",
              "title": "City"
            },
            "description": "City filter"
          },
          {
            "name": "min_stars",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number",
                  "maximum": 5,
                  "minimum": 1
                },
                {
                  "type": "null"
                }
              ],
              "description": "Minimum star rating",
              "title": "Min Stars"
            },
            "description": "Minimum star rating"
          },
          {
            "name": "open_only",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "Only listings currently marked open",
              "default": false,
              "title": "Open Only"
            },
            "description": "Only listings currently marked open"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrowseResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
