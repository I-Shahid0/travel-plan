    "/search": {
      "get": {
        "summary": "Search",
        "operationId": "search_search_get",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "Search query",
              "title": "Q"
            },
            "description": "Search query"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "default": 20,
              "title": "Limit"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 0,
              "description": "Offset (keyword mode only)",
              "default": 0,
              "title": "Offset"
            },
            "description": "Offset (keyword mode only)"
          },
          {
            "name": "mode",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^(hybrid|dense|sparse|keyword)$",
              "description": "Retrieval mode",
              "default": "hybrid",
              "title": "Mode"
            },
            "description": "Retrieval mode"
          },
          {
            "name": "technique",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Query understanding technique (none, constraints, rewrite, multi_query, hyde)",
              "title": "Technique"
            },
            "description": "Query understanding technique (none, constraints, rewrite, multi_query, hyde)"
          },
          {
            "name": "user_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "null"
                }
              ],
              "description": "User ID for personalized ranking",
              "title": "User Id"
            },
            "description": "User ID for personalized ranking"
          },
          {
            "name": "personalize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "Blend user preference into ranking (requires user_id)",
              "default": true,
              "title": "Personalize"
            },
            "description": "Blend user preference into ranking (requires user_id)"
          },
          {
            "name": "price_max",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "integer",
                  "maximum": 4,
                  "minimum": 1
                },
                {
                  "type": "null"
                }
              ],
              "description": "Max price level (1-4)",
              "title": "Price Max"
            },
            "description": "Max price level (1-4)"
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "null"
                }
              ],
              "description": "Category filter",
              "title": "Category"
            },
            "description": "Category filter"
          },
          {
            "name": "city",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "null"
                }
              ],
              "description": "City filter",
              "title": "City"
            },
            "description": "City filter"
          },
          {
            "name": "lat",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number",
                  "maximum": 90,
                  "minimum": -90
                },
                {
                  "type": "null"
                }
              ],
              "description": "Center latitude",
              "title": "Lat"
            },
            "description": "Center latitude"
          },
          {
            "name": "lon",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number",
                  "maximum": 180,
                  "minimum": -180
                },
                {
                  "type": "null"
                }
              ],
              "description": "Center longitude",
              "title": "Lon"
            },
            "description": "Center longitude"
          },
          {
            "name": "radius_km",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "number",
                  "maximum": 500,
                  "exclusiveMinimum": 0
                },
                {
                  "type": "null"
                }
              ],
              "description": "Geo radius in km",
              "title": "Radius Km"
            },
            "description": "Geo radius in km"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
