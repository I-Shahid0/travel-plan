{
  "name": "meridian-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --env-file=../../.env --env-file=.env next dev -p 3001",
    "build": "bun --env-file=../../.env --env-file=.env next build",
    "start": "bun --env-file=../../.env --env-file=.env next start -p 3001",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "generate:api": "openapi-typescript openapi/query.openapi.json -o src/lib/api/query/schema.d.ts && openapi-typescript openapi/itinerary.openapi.json -o src/lib/api/itinerary/schema.d.ts",
    "auth:migrate": "bun --env-file=../../.env --env-file=.env x @better-auth/cli migrate --config src/lib/auth.ts -y",
    "db:migrate": "bun --env-file=../../.env --env-file=.env run scripts/migrate.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@vercel/otel": "^2.1.3",
    "better-auth": "^1.6.23",
    "next": "^16.2.10",
    "openapi-fetch": "^0.17.0",
    "pg": "^8.16.3",
    "prom-client": "^15.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "openapi-typescript": "^7.13.0",
    "playwright-core": "^1.61.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.2"
  }
}
