{
  "uid": "meridian-web",
  "title": "Meridian Web — Frontend & Proxy",
  "tags": ["meridian", "web", "phase-10"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Backend calls from web (req/s by operation)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 12 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service, operation) (rate(meridian_api_client_duration_seconds_count[1m]))",
          "legendFormat": "{{service}} {{operation}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Backend call latency p95 (web-observed)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "fillOpacity": 12 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, operation) (rate(meridian_api_client_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{operation}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "User events recorded (per 5m, by type)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 25 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (increase(meridian_events_recorded_total[5m]))",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "For-You feeds served (by strategy)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 25 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (strategy) (increase(meridian_recommendations_served_total[5m]))",
          "legendFormat": "{{strategy}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Backend call errors (non-2xx/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "fillOpacity": 25 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (service, status) (rate(meridian_api_client_duration_seconds_count{status!~\"2..|ok\"}[5m]))",
          "legendFormat": "{{service}} {{status}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "nginx proxy — requests/s & active connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 12 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(nginx_http_requests_total[1m])",
          "legendFormat": "requests/s"
        },
        {
          "refId": "B",
          "expr": "nginx_connections_active",
          "legendFormat": "active connections"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Web process — resident memory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "fillOpacity": 12 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes{app=\"meridian-web\"}",
          "legendFormat": "resident memory"
        }
      ]
    }
  ]
}
